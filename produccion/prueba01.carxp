 <!-- Plate reverb -->
 <Plugin>
  <Info>
   <Type>LV2</Type>
   <Name>Plate reverb</Name>
   <URI>http://plugin.org.uk/swh-plugins/plate</URI>
  </Info>

  <Data>
   <Active>Yes</Active>
   <ControlChannel>1</ControlChannel>
   <Options>0x0</Options>

   <Parameter>
    <Index>0</Index>
    <Name>Reverb time</Name>
    <Symbol>time</Symbol>
    <MidiChannel>1</MidiChannel>
    <MappedControlIndex>30</MappedControlIndex>
    <MappedMinimum>0.00999999977648258</MappedMinimum>
    <MappedMaximum>8.5</MappedMaximum>
    <MidiCC>30</MidiCC>
    <Value>6.76188945770264</Value>
   </Parameter>

   <Parameter>
    <Index>1</Index>
    <Name>Damping</Name>
    <Symbol>damping</Symbol>
    <Value>0.229999989271164</Value>
   </Parameter>

   <Parameter>
    <Index>2</Index>
    <Name>Dry/wet mix</Name>
    <Symbol>wet</Symbol>
    <Value>0.265957444906235</Value>
   </Parameter>
  </Data>
 </Plugin>

 <!-- Audio File -->
 <Plugin>
  <Info>
   <Type>INTERNAL</Type>
   <Name>Audio File</Name>
   <Label>audiofile</Label>
  </Info>

  <Data>
   <Active>Yes</Active>
   <ControlChannel>1</ControlChannel>
   <Options>0x0</Options>

   <Parameter>
    <Index>0</Index>
    <Name>Loop Mode</Name>
    <Value>1</Value>
   </Parameter>

   <Parameter>
    <Index>1</Index>
    <Name>Host Sync</Name>
    <Value>1</Value>
   </Parameter>

   <Parameter>
    <Index>2</Index>
    <Name>Volume</Name>
    <Value>100</Value>
   </Parameter>

   <Parameter>
    <Index>3</Index>
    <Name>Enabled</Name>
    <Value>1</Value>
   </Parameter>

   <CustomData>
    <Type>http://kxstudio.sf.net/ns/carla/string</Type>
    <Key>file</Key>
    <Value>/home/patch/voces.wav</Value>
   </CustomData>
  </Data>
 </Plugin>

 <!-- Audio Gain (Mono) -->
 <Plugin>
  <Info>
   <Type>INTERNAL</Type>
   <Name>Audio Gain (Mono)</Name>
   <Label>audiogain</Label>
  </Info>

  <Data>
