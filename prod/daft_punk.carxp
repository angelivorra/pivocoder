   </Position>
   <Position x1="1500" y1="850" pluginId="3">
    <Name>Temper</Name>
   </Position>
   <Position x1="1800" y1="850" pluginId="4">
    <Name>ZamTube</Name>
   </Position>
   <Position x1="2100" y1="924" x2="2496" y2="924">
    <Name>Audio Output</Name>
   </Position>
   <Position x1="653" y1="1153" x2="1832" y2="1158">
    <Name>Midi Input</Name>
   </Position>
   <Position x1="1440" y1="1221" x2="2382" y2="1249">
    <Name>Midi Output</Name>
   </Position>
  </Positions>
 </Patchbay>

 <ExternalPatchbay>
