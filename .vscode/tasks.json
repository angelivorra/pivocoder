{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Stop Service",
            "type": "shell",
            "command": "systemctl --user stop pivocoder-flask",
            "problemMatcher": []
        },
        {
            "label": "Start Service",
            "type": "shell",
            "command": "systemctl --user start pivocoder-flask",
            "problemMatcher": []
        },
        {
            "label": "Vaciar Grabaciones",
            "type": "shell",
            "command": "rm -f /home/patch/pivocoder/grabaciones/*",
            "problemMatcher": []
        },
        {
            "label": "Iniciar Grabación",
            "type": "shell",
            "command": "cd /home/patch/pivocoder/grabaciones && jack_capture -f wav",
            "problemMatcher": [],
            "isBackground": true
        },
        {
            "label": "Recortar Grabaciones de voz",
            "type": "shell",
            "command": "/home/patch/venv/bin/python /home/patch/pivocoder/limpia_micro.py --origen /home/patch/pivocoder/grabaciones --destino /home/patch/pivocoder/grabaciones_limpias",
            "problemMatcher": []
        }
        ,
        {
            "label": "Logs",
            "type": "shell",
            "command": "journalctl --user -u pivocoder-flask -f",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new",
                "showReuseMessage": false,
                "clear": true
            },
            "runOptions": {
                "runOn": "default"
            },
            "group": "none"
        }
        ,
        {
            "label": "Arrancar PiVocoder",
            "type": "shell",
            "command": "/home/patch/venv/bin/python /home/patch/pivocoder/flask/app.py",
            "options": {
                "env": {
                    "PORT": "5000",
                    "QT_QPA_PLATFORM": "offscreen"
                }
            },
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            }
        },
        {
            "label": "Arrancar Roboguitarra",
            "type": "shell",
            "command": "/home/patch/venv/bin/python /home/patch/pivocoder/roboguitarra/app.py",
            "options": {
                "env": {
                    "PORT": "5000",
                    "QT_QPA_PLATFORM": "offscreen"
                }
            },
            "problemMatcher": [],
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            }
        }
    ]
}
